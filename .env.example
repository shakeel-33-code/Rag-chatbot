# Copy this file to .env and fill in your values.
# Chat uses the OpenAI client against Hugging Face's OpenAI-compatible router.
# Embeddings stay on Hugging Face feature extraction unless you explicitly configure
# an embeddings-capable OpenAI-compatible endpoint below.
OPENAI_BASE_URL=https://router.huggingface.co/v1
OPENAI_API_KEY=hf_your_huggingface_api_key_here
# Optional separate embedding endpoint and key.
EMBEDDING_OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_OPENAI_API_KEY=your_openai_api_key_here
EMBED_MODEL=BAAI/bge-large-en-v1.5
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_FALLBACK_MODELS=mistralai/Mistral-7B-Instruct-v0.3,HuggingFaceH4/zephyr-7b-beta

PHOENIX_TRACING_ENABLED=true
PHOENIX_PROJECT_NAME=rag-project
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_CAPTURE_CONTENT=true
PHOENIX_CAPTURE_CONTENT_MAX_CHARS=4000
