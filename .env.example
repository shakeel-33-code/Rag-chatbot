# Copy this file to .env and fill in your values.
# Chat uses the OpenAI client against Hugging Face's OpenAI-compatible router.
# Embeddings stay on Hugging Face feature extraction unless you explicitly configure
# an embeddings-capable OpenAI-compatible endpoint below.
OPENAI_BASE_URL=https://router.huggingface.co/v1
OPENAI_API_KEY=hf_your_huggingface_api_key_here
# Optional separate embedding endpoint and key.
EMBEDDING_OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_OPENAI_API_KEY=your_openai_api_key_here
EMBED_MODEL=BAAI/bge-large-en-v1.5
LLM_PROVIDER=huggingface

HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_API_KEY=hf_your_huggingface_api_key_here
HUGGINGFACE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_LLM_FALLBACK_MODELS=mistralai/Mistral-7B-Instruct-v0.3,HuggingFaceH4/zephyr-7b-beta

NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_LLM_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_LLM_FALLBACK_MODELS=mistralai/mistral-7b-instruct-v0.3

OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_LLM_MODEL=gemma4:31b
OLLAMA_LLM_FALLBACK_MODELS=devstral-small-2:24b

LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_FALLBACK_MODELS=mistralai/Mistral-7B-Instruct-v0.3,HuggingFaceH4/zephyr-7b-beta

# Retrieval backend. Use "chroma" for the current embedded store or "qdrant"
# for the production hybrid target.
VECTOR_DB=chroma
DEFAULT_USER_ID=

# Qdrant dense + SPLADE sparse vector settings.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_chunks
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_DISTANCE=Cosine
QDRANT_VECTOR_SIZE=1024
QDRANT_SPARSE_MODEL=
QDRANT_HYBRID_RRF_K=60
QDRANT_DENSE_PREFETCH_LIMIT=20
QDRANT_SPARSE_PREFETCH_LIMIT=20

PHOENIX_TRACING_ENABLED=true
PHOENIX_PROJECT_NAME=rag-project
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_CAPTURE_CONTENT=true
PHOENIX_CAPTURE_CONTENT_MAX_CHARS=4000
